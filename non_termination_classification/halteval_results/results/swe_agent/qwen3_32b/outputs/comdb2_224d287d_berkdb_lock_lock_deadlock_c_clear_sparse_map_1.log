	DB_ENV *dbenv;
	u_int32_t nentries;
	sparse_map_t **sparse_map;

{
	int ret;
	sparse_map_t *map;

	if ((ret = __os_calloc(dbenv, 1, sizeof(sparse_map_t), &map))!=0) {
		return (ret);
	}

