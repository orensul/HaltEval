	if ((ret = __os_calloc(dbenv, sizeof(int *),
		    nentries * 32, &map->alloclist))!=0) {
		free_sparse_map(dbenv, map);

		return (ret);
	}

	map->nentries = nentries;
	map->alloccnt = 0;

	*sparse_map = map;

	return 0;
}
