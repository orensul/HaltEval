void free_cached_idx(uint8_t **cached_idx)
{
    int i;
    if (!cached_idx)
        return;
    for (i = 0; i < MAXINDEX; i++) {
        if (cached_idx[i]) {
            free(cached_idx[i]);
            cached_idx[i] = NULL;
        }
    }
}

static void sqlite3MakeSureDbHasErr(sqlite3 *db, int rc){
    if ((db == NULL) || (db->errCode != SQLITE_OK)) return;
    db->errCode = (rc != SQLITE_OK) ? rc : SQLITE_ERROR;
}

