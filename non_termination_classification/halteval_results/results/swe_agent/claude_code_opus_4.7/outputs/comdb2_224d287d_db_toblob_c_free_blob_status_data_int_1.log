void free_blob_status_data_int(blob_status_t *b, int reset)
{
    int ii;
    for (ii = 0; ii < MAXBLOBS; ii++)
        if (b->blobptrs[ii])
            free(b->blobptrs[ii]);
    if (reset)
        memset(b, 0, sizeof(*b));
}

void free_blob_status_data(blob_status_t *b)
{

    free_blob_status_data_int(b, 1);
}
