#endif
#ifdef LIBXML_SCHEMAS_ENABLED
    xmlInitSchemasTypesInternal();
#endif
#ifdef LIBXML_RELAXNG_ENABLED
    xmlInitRelaxNGInternal();
#endif

    xmlParserInitialized = 1;
}

