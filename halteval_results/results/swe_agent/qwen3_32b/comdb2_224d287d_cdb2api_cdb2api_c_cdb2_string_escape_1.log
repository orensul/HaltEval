    char *curr = strchr(src, *escapestr);
    while (curr != NULL) {
        ++count;
        curr = strchr(curr + 1, *escapestr);
    }

    size_t len = count + strlen(src) + 1;
    char *out = malloc(len);
    char *dest = out;
    strcpy(dest, escapestr);
    ++dest;

    while (*src) {
        curr = strchr(src, *escapestr);
        if (curr == NULL) {
            strcpy(dest, src);
            dest += strlen(src);
            break;
        }

        size_t toklen = curr - src + 1;
        strncpy(dest, src, toklen);

        src = curr + 1;
        dest += toklen;
        strcpy(dest, escapestr);
        ++dest;
    }

    strcpy(dest, escapestr);
    return out;
}

