        s->tablename_len > sizeof(s->tablename)) {
        s->tablename_len = -1;
        return NULL;
    }
    p_buf = (uint8_t *)buf_no_net_get(s->tablename, s->tablename_len, p_buf,
                                      p_buf_end);

