{
    char *ret;

    if (hndl == NULL)
        ret = "unallocated cdb2 handle";
    else {
        if (hndl->fdb_hndl)
            hndl = hndl->fdb_hndl;
        if (hndl->firstresponse == NULL) {
            ret = hndl->errstr;
        } else if (hndl->lastresponse == NULL) {
            ret = hndl->firstresponse->error_string;
        } else {
            ret = hndl->lastresponse->error_string;
        }
    }

    if (!ret)
        ret = hndl->errstr;
    if (log_calls)
        fprintf(stderr, "%p> cdb2_errstr(%p) = \"%s\"\n",
