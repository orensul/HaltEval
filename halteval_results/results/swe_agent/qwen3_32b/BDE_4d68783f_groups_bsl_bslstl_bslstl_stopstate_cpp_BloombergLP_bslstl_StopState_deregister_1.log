//@PURPOSE: Provide a stop state for `std`-compliant stop tokens.
//
//@CLASSES:
//  bslstl::StopState: mechanism for requesting stops and invoking callbacks
//  bslstl::StopStateCallbackNode: base class for stop callbacks
//
