dfvm_value_new_hfinfo(header_field_info *hfinfo, bool raw, bool val_str)
{
	dfvm_value_t *v;

	if (val_str)
		v = dfvm_value_new(HFINFO_VS);
	else if (raw)
		v = dfvm_value_new(RAW_HFINFO);
	else
		v = dfvm_value_new(HFINFO);
	v->value.hfinfo = hfinfo;
	return v;
}

