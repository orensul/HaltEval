#include <bsls_bsltestutil.h>  // for testing only

#include <bsls_platform.h>

#if defined(BSLS_PLATFORM_OS_WINDOWS)
#include <windows.h>
#else
#include <sched.h>  // sched_yield
#endif

namespace BloombergLP {
namespace bsls {

namespace {

/// Schedule another thread to run.
static void yield()
{
#if defined(BSLS_PLATFORM_OS_WINDOWS)
    ::SleepEx(0, 0);
#else
    sched_yield();
#endif
}

}  // close unnamed namespace

                        // -------------
                        // class BslOnce
                        // -------------

// MANIPULATORS
bool BslOnce::doEnter()
{
    int state = bsls::AtomicOperations::testAndSwapInt(&d_onceState,
                                                       e_NOT_ENTERED,
                                                       e_IN_PROGRESS);

    // Verify that 'd_onceState' was correctly initialized.
    BSLS_BSLONCE_ASSERT_SAFE(e_NOT_ENTERED == state ||
                             e_IN_PROGRESS == state ||
                             e_DONE        == state);


    if (state != e_NOT_ENTERED) {
        // Someone had previously entered the one time block, block until it is
        // complete.

        while (state != e_DONE) {
            yield();
            state = bsls::AtomicOperations::getIntAcquire(&d_onceState);

            BSLS_BSLONCE_ASSERT_SAFE(e_IN_PROGRESS == state ||
                                     e_DONE        == state);
        }
        return false;                                                 // RETURN
    }
    return true;
};

}  // close package namespace
}  // close enterprise namespace


