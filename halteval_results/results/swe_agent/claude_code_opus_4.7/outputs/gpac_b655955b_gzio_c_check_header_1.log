		if (s->stream.avail_in == 0) {
			s->z_eof = 1;
			if (gf_ferror(s->file)) s->z_err = Z_ERRNO;
			return EOF;
		}
		s->stream.next_in = s->inbuf;
	}
	s->stream.avail_in--;
	return *(s->stream.next_in)++;
}

