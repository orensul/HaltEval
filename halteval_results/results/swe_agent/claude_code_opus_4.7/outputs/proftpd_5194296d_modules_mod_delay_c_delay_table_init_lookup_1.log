  }

  lookupsz = server_count * 3 * sizeof(unsigned int);
  lookup = pcalloc(delay_pool, lookupsz);

  i = r = 0;
  for (s = (server_rec *) server_list->xas_list; s; s = s->next) {
    /* SID */
    lookup[i] = s->sid;

