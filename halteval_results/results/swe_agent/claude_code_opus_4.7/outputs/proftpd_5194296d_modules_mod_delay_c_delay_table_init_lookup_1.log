    lookup[i+1] = r;

    /* SID-specific PASS row */
    lookup[i+2] = r + 1;

    i += 3;
    r += 2;
  }

  delay_tab.dt_lookupsz = lookupsz;
  delay_tab.dt_lookup = lookup;
